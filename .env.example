# 数据库路径（默认：data/etf_sequoia.db；若曾用股票版库请换新路径并重新 backfill）
DB_PATH=data/etf_sequoia.db

# 数据起始日期（默认：2024-01-01）
START_DATE=2024-01-01

# 默认飞书 Webhook URL（必填；日常合并日报默认发至此，除非单独配置了 digest）
FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/your-default-token

# 合并日报专属 Webhook（可选）。设置后推荐卡片只发到此 URL。
# STRATEGY_WEBHOOK_DIGEST=https://open.feishu.cn/open-apis/bot/v2/hook/your-digest-token

# 合并日报：推荐数量、每策略展示条数（可选）
# FEISHU_DIGEST_TOP_N=5
# FEISHU_MORNING_TOP_N=5
# FEISHU_DIGEST_MAX_PER_STRATEGY_DISPLAY=30
# FEISHU_PUSH_MODE_DEFAULT=auto
# FEISHU_CARD_MAX_BYTES_GUARD=20000
# FEISHU_SEND_MIN_INTERVAL_SECONDS=0.25
# FEISHU_ENABLE_INTRADAY_WARNING=true

# 新增策略（高胜率偏好）参数示例
# ENABLE_DUAL_MOMENTUM_ROTATION_STRATEGY=true
# ENABLE_TREND_STABILITY_MOMENTUM_STRATEGY=true
# ENABLE_LOW_VOL_MOMENTUM_BLEND_STRATEGY=true
# DMR_MIN_TURNOVER_20D=10000000
# DMR_MAX_5D_RETURN_PCT=0.12
# DMR_MAX_RESULTS=20
# TSM_LOOKBACK_DAYS=30
# TSM_MIN_TURNOVER_20D=10000000
# TSM_MAX_5D_RETURN_PCT=0.12
# TSM_MAX_RESULTS=20
# LVMB_MIN_TURNOVER_20D=10000000
# LVMB_MAX_VOLATILITY_20D=0.035
# LVMB_MAX_5D_RETURN_PCT=0.10
# LVMB_MAX_RESULTS=20

# 以下为历史「按策略分机器人」占位；当前日常模式不再逐策略推送，可删除或保留无影响。
# STRATEGY_WEBHOOK_MA_VOLUME=...

# 保守版参数（高胜率 / 低回撤倾向，可直接取消注释生效）
# ENABLE_ETF_STRONG_PULLBACK_STRATEGY=false
# ENABLE_ETF_UPTREND_SHARP_DROP_STRATEGY=false
# STLC_MIN_TURNOVER_20D=10000000
# STLC_MAX_5D_RETURN_PCT=0.10
# STLC_MAX_DISTANCE_FROM_MA20=0.08
# STLC_MAX_UPPER_SHADOW_RATIO=0.30
# STLC_MIN_CLOSE_POSITION_RATIO=0.70
# VCB_CONTRACTION_MAX_RANGE_RATIO=0.10
# VCB_VOLUME_BREAKOUT_MULTIPLIER=1.8
# VCB_MAX_5D_RETURN_PCT=0.10
# VCB_MIN_CLOSE_POSITION_RATIO=0.70
# INDUSTRY_ROTATION_TOP_GROUPS=3
# INDUSTRY_ROTATION_PICK_PER_GROUP=1
# INDUSTRY_ROTATION_MAX_5D_RETURN_PCT=0.10
